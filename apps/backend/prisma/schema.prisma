// apps/backend/prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TransmissionType {
  Automatic
  Manual
}

enum CarStatus {
  Active
  Maintenance
}

enum DriverStatus {
  Free
  Busy
  Offline
}

enum TripStatus {
  Scheduled
  Active
  Ended
  Cancelled
}

model Car {
  id               String           @id @default(uuid())
  brand            String
  licensePlate     String           @unique
  transmissionType TransmissionType
  status           CarStatus        @default(Active)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // A car can be used in multiple trips
  trips            Trip[]
}

model Agent {
  id             String        @id @default(uuid())
  name           String        @unique
  contactDetails String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relationships
  driverAgents   DriverAgent[]
  trips          Trip[]
}

model Driver {
  id             String        @id @default(uuid())
  name           String
  phoneNumber    String        @unique
  status         DriverStatus  @default(Offline)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relationships
  driverAgents   DriverAgent[]
  trips          Trip[]
}

// Explicit Many-to-Many Relationship Table
model DriverAgent {
  driverId   String
  agentId    String
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([driverId, agentId])
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  trips     Trip[]
}

model Trip {
  id                  String     @id @default(uuid())
  stops               String[]
  startTime           DateTime   @default(now())
  estimatedCompletion DateTime?
  startDate           DateTime   @default(now())
  endDate             DateTime?
  status              TripStatus @default(Active)

  // Payment fields
  advancePaid         Float      @default(0)
  fuelExpense         Float      @default(0)
  pendingAmount       Float      @default(0)

  // Shareable token for public customer portal
  shareToken          String?    @unique

  // Relationships
  driverId            String
  driver              Driver     @relation(fields: [driverId], references: [id], onDelete: Restrict)
  carId               String
  car                 Car        @relation(fields: [carId], references: [id], onDelete: Restrict)
  agentId             String
  agent               Agent      @relation(fields: [agentId], references: [id], onDelete: Restrict)
  customerId          String?
  customer            Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Feedback (1:1)
  feedback            Feedback?
}

model Feedback {
  id         String   @id @default(uuid())
  stars      Int
  experience String
  reason     String?
  createdAt  DateTime @default(now())

  // Relationship
  tripId     String   @unique
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}
