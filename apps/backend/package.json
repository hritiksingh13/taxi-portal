{
  "name": "taxi-management-backend",
  "version": "1.0.0",
  "description": "Real-time backend for taxi fleet operations",
  "main": "src/server.ts",
  "scripts": {
    "start": "ts-node src/server.ts",
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node src/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "socket.io": "^4.7.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "nodemon": "^3.1.0",
    "prisma": "5.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
